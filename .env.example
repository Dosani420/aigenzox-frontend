# API base URL
VITE_API_BASE_URL=http://localhost:5000

# Easy site-mode switch
# true  = show Coming Soon page
# false = show full site
VITE_COMING_SOON=false

# Remove.bg API Configuration
# Get your API key from: https://www.remove.bg/api
VITE_REMOVE_BG_API_KEY=your-remove-bg-api-key-here

# Example:
# VITE_REMOVE_BG_API_KEY=abc123def456ghi789